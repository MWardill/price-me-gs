{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: price-me-gs",
      "runtimeArgs": [
        "--env-file=${workspaceFolder}/dev.env",
        "--import=tsx"
